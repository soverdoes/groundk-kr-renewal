{
  "$schema": "https://schemas.designtokens.org/0.1/tokens.json",
  "$description": "GroundK Design System — design tokens extracted from groundk.com production CSS (variable.css / common.css / main.css / sub.css). Format: W3C DTCG (Design Tokens Community Group). Reference viewports: desktop 1920px (1vw = 19.2px), mobile 360px (1vw = 3.6px).",

  "color": {
    "$description": "Primitive palette. Raw brand and neutral values used as the base of all semantic colors.",
    "base": {
      "black":   { "$type": "color", "$value": "#0F0F0F" },
      "white":   { "$type": "color", "$value": "#FFFFFF" },
      "navy":    { "$type": "color", "$value": "#2E3192", "$description": "Brand primary — GroundK blue/navy." },
      "cyan":    { "$type": "color", "$value": "#2BD9FF", "$description": "Brand secondary — accent / active state." },
      "gray-400":{ "$type": "color", "$value": "#C4C4C4", "$description": "Border gray." },
      "gray-500":{ "$type": "color", "$value": "#B0B0B0", "$description": "Mid gray — footer sub links, labels." },
      "gray-600":{ "$type": "color", "$value": "#636363", "$description": "Pass-through marquee text." },
      "gray-700":{ "$type": "color", "$value": "#5C5C5C", "$description": "Secondary text." },
      "gray-050":{ "$type": "color", "$value": "#F8F8F8", "$description": "Off-white section background." }
    },
    "alpha": {
      "black-10": { "$type": "color", "$value": "rgba(15, 15, 15, 0.1)" },
      "black-20": { "$type": "color", "$value": "rgba(0, 0, 0, 0.2)" },
      "black-35": { "$type": "color", "$value": "rgba(0, 0, 0, 0.35)" },
      "black-50": { "$type": "color", "$value": "rgba(0, 0, 0, 0.5)" },
      "black-60": { "$type": "color", "$value": "rgba(0, 0, 0, 0.6)" },
      "black-70": { "$type": "color", "$value": "rgba(0, 0, 0, 0.7)" },
      "white-10": { "$type": "color", "$value": "rgba(255, 255, 255, 0.1)" },
      "white-90": { "$type": "color", "$value": "rgba(248, 248, 248, 0.9)" }
    }
  },

  "theme": {
    "$description": "Semantic color tokens. Light is the default; dark maps to :root[data-theme=\"dark\"].",
    "light": {
      "primary":         { "$type": "color", "$value": "{color.base.navy}" },
      "primary-invert":  { "$type": "color", "$value": "{color.base.white}" },
      "secondary":       { "$type": "color", "$value": "{color.base.cyan}" },
      "text":            { "$type": "color", "$value": "{color.base.black}" },
      "text-sub":        { "$type": "color", "$value": "{color.base.gray-700}" },
      "text-fill":       { "$type": "color", "$value": "{color.alpha.black-10}", "$description": "txt-mask scroll-reveal under-fill." },
      "border":          { "$type": "color", "$value": "{color.base.gray-400}" },
      "background":      { "$type": "color", "$value": "{color.base.white}" }
    },
    "dark": {
      "primary":         { "$type": "color", "$value": "{color.base.white}" },
      "primary-invert":  { "$type": "color", "$value": "{color.base.navy}" },
      "secondary":       { "$type": "color", "$value": "{color.base.cyan}" },
      "text":            { "$type": "color", "$value": "{color.base.white}" },
      "text-sub":        { "$type": "color", "$value": "{color.base.white}" },
      "text-fill":       { "$type": "color", "$value": "{color.alpha.white-10}" },
      "border":          { "$type": "color", "$value": "{color.base.gray-400}" },
      "background":      { "$type": "color", "$value": "{color.base.black}" }
    }
  },

  "fontFamily": {
    "primary": { "$type": "fontFamily", "$value": ["Pretendard Variable", "Pretendard", "sans-serif"], "$description": "Body / Korean+Latin. Variable font." },
    "display": { "$type": "fontFamily", "$value": ["termina", "Pretendard Variable", "Pretendard", "sans-serif"], "$description": "Adobe Typekit. English display, numerals, stroke text, GroundK wordmark. Termina is Latin-only; Pretendard fallback renders Korean glyphs on /kr pages (Hangul auto-routes to Pretendard, Latin/numerals stay Termina)." }
  },

  "fontWeight": {
    "regular": { "$type": "fontWeight", "$value": 400 },
    "medium":  { "$type": "fontWeight", "$value": 500 },
    "bold":    { "$type": "fontWeight", "$value": 700 }
  },

  "lineHeight": {
    "none":    { "$type": "number", "$value": 1 },
    "tight":   { "$type": "number", "$value": 1.06 },
    "snug":    { "$type": "number", "$value": 1.08 },
    "heading": { "$type": "number", "$value": 1.2 },
    "body":    { "$type": "number", "$value": 1.3 },
    "hero":    { "$type": "number", "$value": 0.95, "$description": "Hero display only." }
  },

  "letterSpacing": {
    "tight": { "$type": "dimension", "$value": "-0.052vw", "$description": "≈ -1px @1920. Used on fleet type title." }
  },

  "fontSize": {
    "$description": "Fluid sizes are authored in vw. value = desktop vw @1920. Desktop px shown in $description; mobile px differs (see typography styles).",
    "base":  { "$type": "dimension", "$value": "0.833vw", "$description": "16px @1920 — root font-size." },
    "18":    { "$type": "dimension", "$value": "0.938vw", "$description": "18px @1920" },
    "20":    { "$type": "dimension", "$value": "1.042vw", "$description": "20px @1920" },
    "24":    { "$type": "dimension", "$value": "1.25vw",  "$description": "24px @1920" },
    "28":    { "$type": "dimension", "$value": "1.458vw", "$description": "28px @1920" },
    "32":    { "$type": "dimension", "$value": "1.667vw", "$description": "32px @1920" },
    "42":    { "$type": "dimension", "$value": "2.188vw", "$description": "42px @1920" },
    "48":    { "$type": "dimension", "$value": "2.5vw",   "$description": "48px @1920" },
    "52":    { "$type": "dimension", "$value": "2.708vw", "$description": "52px @1920" },
    "58":    { "$type": "dimension", "$value": "3.021vw", "$description": "58px @1920" },
    "67":    { "$type": "dimension", "$value": "3.49vw",  "$description": "67px @1920" },
    "72":    { "$type": "dimension", "$value": "3.75vw",  "$description": "72px @1920" },
    "80":    { "$type": "dimension", "$value": "4.167vw", "$description": "80px @1920" },
    "84":    { "$type": "dimension", "$value": "4.375vw", "$description": "84px @1920" },
    "100":   { "$type": "dimension", "$value": "5.208vw", "$description": "100px @1920" },
    "140":   { "$type": "dimension", "$value": "7.292vw", "$description": "140px @1920" },
    "190":   { "$type": "dimension", "$value": "9.896vw", "$description": "190px @1920" }
  },

  "spacing": {
    "$description": "4px base scale. value = vw @1920; name = desktop px. Container/section helpers at end.",
    "4":   { "$type": "dimension", "$value": "0.208vw", "$description": "4px @1920" },
    "8":   { "$type": "dimension", "$value": "0.417vw", "$description": "8px @1920" },
    "10":  { "$type": "dimension", "$value": "0.521vw", "$description": "10px @1920" },
    "12":  { "$type": "dimension", "$value": "0.625vw", "$description": "12px @1920" },
    "16":  { "$type": "dimension", "$value": "0.833vw", "$description": "16px @1920" },
    "20":  { "$type": "dimension", "$value": "1.042vw", "$description": "20px @1920" },
    "24":  { "$type": "dimension", "$value": "1.25vw",  "$description": "24px @1920" },
    "28":  { "$type": "dimension", "$value": "1.458vw", "$description": "28px @1920" },
    "32":  { "$type": "dimension", "$value": "1.667vw", "$description": "32px @1920" },
    "36":  { "$type": "dimension", "$value": "1.875vw", "$description": "36px @1920" },
    "40":  { "$type": "dimension", "$value": "2.083vw", "$description": "40px @1920" },
    "44":  { "$type": "dimension", "$value": "2.292vw", "$description": "44px @1920" },
    "48":  { "$type": "dimension", "$value": "2.5vw",   "$description": "48px @1920" },
    "52":  { "$type": "dimension", "$value": "2.708vw", "$description": "52px @1920" },
    "56":  { "$type": "dimension", "$value": "2.917vw", "$description": "56px @1920 — title→body gap." },
    "60":  { "$type": "dimension", "$value": "3.125vw", "$description": "60px @1920" },
    "64":  { "$type": "dimension", "$value": "3.333vw", "$description": "64px @1920" },
    "80":  { "$type": "dimension", "$value": "4.167vw", "$description": "80px @1920 — container side padding." },
    "100": { "$type": "dimension", "$value": "5.208vw", "$description": "100px @1920" },
    "120": { "$type": "dimension", "$value": "6.25vw",  "$description": "120px @1920 — standard section padding." }
  },

  "radius": {
    "none": { "$type": "dimension", "$value": "0",       "$description": "Default — buttons, tabs." },
    "sm":   { "$type": "dimension", "$value": "0.417vw", "$description": "8px @1920 — header glass pills." },
    "md":   { "$type": "dimension", "$value": "1.042vw", "$description": "20px @1920 — cards, screen slides." },
    "lg":   { "$type": "dimension", "$value": "2.222vw", "$description": "Mobile card radius." },
    "full": { "$type": "dimension", "$value": "100%",    "$description": "Avatars, dots." }
  },

  "borderWidth": {
    "hairline": { "$type": "dimension", "$value": "1px", "$description": "Default rules, button outlines, dividers." },
    "thick":    { "$type": "dimension", "$value": "0.156vw", "$description": "3px @1920 — screen-slide frame, nav underline." }
  },

  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": { "color": "{color.alpha.black-20}", "offsetX": "-0.104vw", "offsetY": "0.313vw", "blur": "1.302vw", "spread": "0" },
      "$description": "Review card. ≈ -2px 6px 25px rgba(0,0,0,0.16)."
    },
    "screen": {
      "$type": "shadow",
      "$value": { "color": "{color.alpha.black-20}", "offsetX": "-0.417vw", "offsetY": "0.26vw", "blur": "1.042vw", "spread": "0" },
      "$description": "Screen slide. ≈ -8px 5px 20px rgba(0,0,0,0.16)."
    },
    "drop": {
      "$type": "shadow",
      "$value": { "color": "{color.alpha.black-20}", "offsetX": "0", "offsetY": "0.26vw", "blur": "1.042vw", "spread": "0" },
      "$description": "filter: drop-shadow on featured images. ≈ 0 5px 20px rgba(0,0,0,0.16)." }
  },

  "blur": {
    "glass": { "$type": "dimension", "$value": "15px", "$description": "backdrop-filter for header / nav-sub glass panels." }
  },

  "duration": {
    "fast": { "$type": "duration", "$value": "300ms", "$description": "All hover/state/theme transitions." }
  },

  "easing": {
    "out": { "$type": "cubicBezier", "$value": [0, 0, 0.58, 1], "$description": "ease-out — the system's single easing." }
  },

  "breakpoint": {
    "$description": "Layout switches on aspect ratio (portrait), not width. Width queries are auxiliary.",
    "mobile":      { "$type": "dimension", "$value": "(max-aspect-ratio: 10/9)", "$description": "Primary mobile/portrait switch." },
    "tabletPro":   { "$type": "dimension", "$value": "1366px" },
    "tablet":      { "$type": "dimension", "$value": "1024px" },
    "phone":       { "$type": "dimension", "$value": "640px" },
    "refDesktop":  { "$type": "dimension", "$value": "1920px", "$description": "Desktop design reference width." },
    "refMobile":   { "$type": "dimension", "$value": "360px",  "$description": "Mobile design reference width." }
  }
}
